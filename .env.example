# ==============================
# RAVO OS — Environment Variables
# ==============================
# ⚠️ NUNCA COMMITAR .env em git — APENAS .env.example
# Use: cp .env.example .env.local

# ========== SUPABASE ==========
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anonima_aqui

# ========== AUTHENTICATION ==========
VITE_AUTH_METHOD=supabase
VITE_SESSION_TIMEOUT_MINUTES=60
VITE_OAUTH_GOOGLE_CLIENT_ID=seu_google_client_id
VITE_OAUTH_GITHUB_CLIENT_ID=seu_github_client_id

# ========== API CONFIGURATION ==========
VITE_API_BASE_URL=https://seu-backend.com/api
VITE_API_TIMEOUT_MS=5000

# ========== FEATURE FLAGS ==========
VITE_ENABLE_REAL_TIME=true
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_DEBUG_MODE=false

# ========== UI CONFIGURATION ==========
VITE_APP_TITLE=RAVO | Central de Operações
VITE_APP_LOGO_URL=/logo.svg
VITE_APP_VERSION=2.0.0

# ========== ANALYTICS ==========
VITE_ANALYTICS_ID=seu_analytics_id
VITE_SENTRY_DSN=seu_sentry_dsn

# ========== DEPLOYMENT ==========
VITE_ENVIRONMENT=development  # development, staging, production
VITE_API_RATE_LIMIT_ENABLED=false
