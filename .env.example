# ==============================
# RAVO OS — Environment Variables
# ==============================
# NUNCA COMMITAR .env em git — APENAS .env.example
# Use: cp .env.example .env

# Supabase Configuration
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anonima_aqui

# Auth Configuration
VITE_AUTH_METHOD=supabase  # ou 'oauth', 'custom'
VITE_SESSION_TIMEOUT_MINUTES=60

# API Configuration
VITE_API_BASE_URL=https://seu-backend.com/api
VITE_API_TIMEOUT_MS=5000

# Feature Flags
VITE_ENABLE_REAL_TIME=true
VITE_ENABLE_OFFLINE_MODE=false
VITE_ENABLE_ANALYTICS=true

# UI Configuration
VITE_APP_TITLE=RAVO | Central de Operações
VITE_APP_LOGO_URL=/logo.svg
